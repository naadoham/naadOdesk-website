<!-- Razorpay + intl-tel-input SDKs -->
<script data-cfasync="false" src="/cdn-cgi/scripts/5c5dd728/cloudflare-static/email-decode.min.js"></script><script src="https://checkout.razorpay.com/v1/checkout.js"></script>
<script src="https://cdn.jsdelivr.net/npm/intl-tel-input@18.2.1/build/js/intlTelInput.min.js"></script>

<script>
// ══ Config (same as buy page) ════════════════════════════════
const SB_URL          = "https://hjiaimhfejkvwgsalpwh.supabase.co";
const SB_ANON_KEY     = "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImhqaWFpbWhmZWprdndnc2FscHdoIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzM2MjAxMzMsImV4cCI6MjA4OTE5NjEzM30.PfeSv88-4Ta5p-fbl2CByuSCJALVWFdliue4I4Xa2TI";
const RAZORPAY_KEY_ID = "rzp_live_SRRlbofF4AAtwd";
const ORDER_URL       = SB_URL + "/functions/v1/razorpay-order";

let iti, mobileInput, _settings = null;
const _t0 = Date.now();
let _appliedRef = null, _appliedCoup = null;

// ── intl-tel-input init ──────────────────────────────────────
// ── index.html: no buy form, load settings immediately like buy.html ──
window._detectedCountry = "in";
loadSettings();

// Detect country in parallel — agar international user hai to price update karo
fetch("https://ipapi.co/json/")
  .then(r => r.json())
  .then(d => {
    const cc = (d.country_code || "in").toLowerCase();
    if (cc !== window._detectedCountry) {
      window._detectedCountry = cc;
      updatePriceDisplay();
    }
  })
  .catch(() => {});

// ── Load settings + update all prices ───────────────────────
async function loadSettings() {
  try {
    const res  = await fetch(SB_URL + "/rest/v1/settings?select=*&limit=1", {
      headers: { "apikey": SB_ANON_KEY, "Authorization": "Bearer " + SB_ANON_KEY }
    });
    if (!res.ok) throw new Error("HTTP " + res.status);
    const data = await res.json();
    if (data && data.length) {
      _settings = data[0];
      console.log("[naadOdesk] Settings loaded:", {
        price_india: _settings.product_price_india,
        price_global: _settings.product_price_global,
        download_url: _settings.download_url,
        app_version: _settings.app_version,
        promo_coupon_code: _settings.promo_coupon_code
      });
    } else {
      console.warn("[naadOdesk] Settings table returned empty array — check Supabase row id=1");
    }
  } catch(e) {
    console.error("[naadOdesk] Settings fetch failed:", e);
  }
  updatePriceDisplay();
  updateDownloadButton();
  loadPromoBanner();
}

// ── Download button URL from settings ────────────────────────
// ── Google Drive URL ko direct download link mein convert karo ──
function toDirectDownload(url) {
  if (!url) return url;
  // Format 1: /file/d/FILE_ID/view
  const m1 = url.match(/\/file\/d\/([^\/\?]+)/);
  if (m1) return "https://drive.google.com/uc?export=download&id=" + m1[1];
  // Format 2: id=FILE_ID already in URL
  const m2 = url.match(/[?&]id=([^&]+)/);
  if (m2) return "https://drive.google.com/uc?export=download&id=" + m2[1];
  // Format 3: /open?id=FILE_ID
  const m3 = url.match(/\/open\?id=([^&]+)/);
  if (m3) return "https://drive.google.com/uc?export=download&id=" + m3[1];
  // Not a Drive link — return as-is
  return url;
}

function updateDownloadButton() {
  const rawUrl       = _settings?.download_url;
  const url          = toDirectDownload(rawUrl)
                       || "https://drive.google.com/uc?export=download&id=1euXeEI6EONvIadkLFHR9iABZhVubI7KM";
  const version      = _settings?.app_version;
  const releaseNotes = _settings?.release_notes;

  const btn = document.getElementById("dlBtn");
  if (btn) {
    // Use onclick so browser never previews — always direct download
    btn.onclick = function(e) {
      e.preventDefault();
      window.open(url, "_blank");
    };
    btn.removeAttribute("disabled");
    console.log("[naadOdesk] Download URL set:", url);
  }

  const elVer = document.getElementById("dlVersion");
  if (elVer && version) elVer.textContent = version;

  const elNotes     = document.getElementById("dlNotes");
  const elNotesText = document.getElementById("dlNotesText");
  if (elNotes && elNotesText && releaseNotes) {
    elNotesText.textContent = releaseNotes;
    elNotes.style.display   = "block";
  }
}

// ── version.json fallback — agar Supabase mein download_url na ho ──
fetch("/version.json")
  .then(r => r.json())
  .then(v => {
    // Only use version.json if Supabase ne URL nahi diya
    const btn  = document.getElementById("dlBtn");
    const elVer = document.getElementById("dlVersion");
    if (btn && btn.getAttribute("href") === "#" && v.download_url) {
      btn.href   = toDirectDownload(v.download_url);
      btn.target = "_blank";
      btn.rel    = "noopener";
      console.log("[naadOdesk] Download URL loaded from version.json:", v.download_url);
    }
    if (elVer && elVer.textContent === "—" && v.version) {
      elVer.textContent = v.version + " (" + v.build + ")";
    }
    const elNotes     = document.getElementById("dlNotes");
    const elNotesText = document.getElementById("dlNotesText");
    if (elNotes && elNotesText && elNotes.style.display === "none" && v.release_notes) {
      elNotesText.textContent = v.release_notes;
      elNotes.style.display   = "block";
    }
  })
  .catch(() => {});  // version.json nahi mili toh koi problem nahi

// ── Promo Banner ─────────────────────────────────────────────
async function loadPromoBanner() {
  const code    = _settings?.promo_coupon_code;
  const tagline = _settings?.promo_tagline;
  if (!code) return; // koi active promo nahi set

  // Step 1: settings mein hi promo_discount_percent hai toh seedha banner dikhao
  const settingsDiscount = _settings?.promo_discount_percent;
  if (settingsDiscount) {
    showPromoBanner(code, tagline, settingsDiscount);
    return;
  }

  // Step 2: fallback — coupons table se discount fetch karo
  try {
    const res = await fetch(SB_URL + "/rest/v1/coupons?code=eq." + encodeURIComponent(code) + "&select=*", {
      headers: { "apikey": SB_ANON_KEY, "Authorization": "Bearer " + SB_ANON_KEY }
    });
    const data = await res.json();
    const cp = data?.[0];
    if (!cp) {
      // Coupon table mein record nahi — phir bhi banner dikhao bina discount ke
      showPromoBanner(code, tagline, null);
      return;
    }
    if (cp.is_disabled) return;
    if (cp.expiry_date && new Date(cp.expiry_date) < new Date()) return;
    if (cp.max_uses && cp.used_count >= cp.max_uses) return;
    showPromoBanner(cp.code, tagline, cp.discount_percent);
  } catch(e) {
    // Network fail — phir bhi banner dikhao, discount ke bina
    console.warn("[naadOdesk] Coupon fetch failed, showing banner anyway:", e);
    showPromoBanner(code, tagline, null);
  }
}

function showPromoBanner(code, tagline, discountPercent) {
  document.getElementById("promoCodeChip").textContent = code;
  document.getElementById("promoTagline").textContent  = tagline || "Limited time offer!";
  if (discountPercent) {
    document.getElementById("promoDisc").textContent = discountPercent + "%";
    document.getElementById("promoDisc").parentElement.style.display = "";
  } else {
    // Discount nahi pata — sirf disc element hide karo
    const discEl = document.getElementById("promoDisc");
    if (discEl && discEl.parentElement) discEl.parentElement.style.display = "none";
  }
  document.getElementById("promoBanner").style.setProperty("display", "block", "important");
  console.log("[naadOdesk] Promo banner shown:", code, discountPercent ? discountPercent+"%" : "(no discount)");
}

function copyPromoCode() {
  const code = document.getElementById("promoCodeChip").textContent;
  navigator.clipboard.writeText(code).then(() => {
    const el = document.getElementById("promoCopied");
    el.style.display = "inline";
    setTimeout(() => { el.style.display = "none"; }, 2000);
  }).catch(() => {
    // fallback for older browsers
    const ta = document.createElement("textarea");
    ta.value = code; document.body.appendChild(ta); ta.select();
    document.execCommand("copy"); document.body.removeChild(ta);
    const el = document.getElementById("promoCopied");
    el.style.display = "inline";
    setTimeout(() => { el.style.display = "none"; }, 2000);
  });
}

function getBasePrice() {
  let isIndia;
  if (iti) {
    isIndia = (iti.getSelectedCountryData().iso2||"in").toLowerCase() === "in";
  } else {
    isIndia = (window._detectedCountry || "in") === "in";
  }
  return {
    price:  isIndia ? Number(_settings?.product_price_india || _settings?.product_price || _settings?.price || 999) : Number(_settings?.product_price_global || _settings?.price || 19),
    symbol: isIndia ? "₹" : "$",
    curr:   isIndia ? "INR" : "USD"
  };
}

function updatePriceDisplay() {
  const { price, symbol, curr } = _settings
    ? getBasePrice()
    : { price: 999, symbol: "₹", curr: "INR" };
  const label = symbol + price;

  // All price elements on page (safe — check before update)
  const elSym  = document.getElementById("priceSymbol");
  const elNum  = document.getElementById("priceNumber");
  const elHero = document.getElementById("heroPriceLabel");
  const elNav  = document.getElementById("navBuyBtn");
  const elStrip= document.getElementById("stripPrice");
  const elBtn  = document.getElementById("btnPrice");
  const elBuy  = document.getElementById("btnBuy");
  const elDesc = document.getElementById("priceDesc");

  if (elSym)   elSym.textContent  = symbol;
  if (elNum)   { elNum.textContent = price; elNum.classList.remove("loading"); }
  if (elHero)  elHero.textContent = label;
  if (elNav)   elNav.textContent  = "Buy — " + label;
  if (elStrip) elStrip.textContent= label;
  if (elBtn)   elBtn.textContent  = label;
  if (elBuy)   elBuy.disabled     = false;
  if (elDesc)  elDesc.textContent = "One-time payment · " + curr + " · Bug fixes free · macOS";
}

// ── Discount helpers ─────────────────────────────────────────
function setStatus(id, text, ok) {
  const el = document.getElementById(id);
  if (!text) { el.style.display="none"; return; }
  el.textContent = text; el.style.display = "block";
  el.style.background = ok ? "rgba(48,209,88,.08)" : "rgba(255,78,106,.08)";
  el.style.color      = ok ? "#30d158" : "#ff4e6a";
  el.style.border     = ok ? "1px solid rgba(48,209,88,.2)" : "1px solid rgba(255,78,106,.2)";
}

function refreshPriceSummary() {
  const { price, symbol } = getBasePrice();
  let final = price, html = "";
  if (_appliedCoup) {
    html  += "<div>🏷️ Coupon <b style='color:#fff'>" + _appliedCoup.code + "</b> &nbsp;<span style='color:#30d158'>-" + symbol + _appliedCoup.disc + "</span></div>";
    final -= _appliedCoup.disc;
  }
  if (_appliedRef) {
    const rd = _appliedRef.isPercent ? Math.round(final * _appliedRef.pct / 100) : _appliedRef.disc;
    html  += "<div>🔗 Referral <b style='color:#fff'>" + _appliedRef.code + "</b> &nbsp;<span style='color:#30d158'>-" + symbol + rd + "</span></div>";
    final -= rd;
  }
  final = Math.max(final, 1);
  if (html) {
    html = "<div style='color:#555;font-size:11px;margin-bottom:4px;'>Original: <span style='text-decoration:line-through'>" + symbol + price + "</span></div>" + html;
    document.getElementById("discountLines").innerHTML = html;
    document.getElementById("finalPriceDisplay").textContent = symbol + final;
    document.getElementById("discountBox").style.display = "block";
    document.getElementById("btnPrice").textContent = symbol + final;
  } else {
    document.getElementById("discountBox").style.display = "none";
    updatePriceDisplay();
  }
}

async function applyCodes() {
  const refCode  = document.getElementById("referralCode").value.trim().toUpperCase();
  const coupCode = document.getElementById("couponCode").value.trim().toUpperCase();
  const btn = document.getElementById("applyBtn");
  _appliedRef = null; _appliedCoup = null;
  setStatus("refStatus","",true); setStatus("coupStatus","",true);
  btn.textContent = "Checking…"; btn.disabled = true;
  const { price, symbol } = getBasePrice();
  if (refCode) {
    try {
      const res  = await fetch(SB_URL+"/rest/v1/referrals?referral_code=eq."+encodeURIComponent(refCode)+"&select=*", { headers: { apikey: SB_ANON_KEY, Authorization: "Bearer "+SB_ANON_KEY } });
      const data = await res.json();
      if (!data?.length) { setStatus("refStatus","❌ Referral code not found",false); }
      else {
        const ref = data[0];
        let disc = ref.discount_type==="percent" ? Math.round(price*ref.discount_value/100) : Number(ref.discount_value||0);
        _appliedRef = { code:refCode, disc, isPercent:ref.discount_type==="percent", pct:ref.discount_value||0 };
        setStatus("refStatus","✅ Applied",true);
      }
    } catch(e) { setStatus("refStatus","⚠️ Could not verify",false); }
  }
  if (coupCode) {
    try {
      const res  = await fetch(SB_URL+"/rest/v1/coupons?code=eq."+encodeURIComponent(coupCode)+"&select=*", { headers: { apikey: SB_ANON_KEY, Authorization: "Bearer "+SB_ANON_KEY } });
      const data = await res.json();
      if (!data?.length) { setStatus("coupStatus","❌ Coupon not found",false); }
      else {
        const cp = data[0];
        if (cp.is_disabled) setStatus("coupStatus","❌ Coupon is disabled",false);
        else if (cp.max_uses && cp.used_count >= cp.max_uses) setStatus("coupStatus","❌ Usage limit reached",false);
        else if (cp.expiry_date && new Date(cp.expiry_date) < new Date()) setStatus("coupStatus","❌ Coupon expired",false);
        else { const disc = Math.round(price*cp.discount_percent/100); _appliedCoup={code:coupCode,disc}; setStatus("coupStatus","✅ Applied — "+symbol+disc+" off",true); }
      }
    } catch(e) { setStatus("coupStatus","⚠️ Could not verify",false); }
  }
  btn.textContent = "Apply Codes"; btn.disabled = false;
  refreshPriceSummary();
}

// ── State helpers ────────────────────────────────────────────
function showState(id) {
  ["stateForm","stateProcessing","stateSuccess","stateError"].forEach(s => document.getElementById(s).classList.toggle("active", s===id));
}
function resetForm() { document.getElementById("btnBuy").disabled = false; showState("stateForm"); }
function uuidv4() {
  return "xxxxxxxx-xxxx-4xxx-yxxx-xxxxxxxxxxxx".replace(/[xy]/g, c => { const r=Math.random()*16|0; return (c==="x"?r:(r&0x3|0x8)).toString(16); });
}

// ── Main payment flow ────────────────────────────────────────
async function startPayment() {
  if (document.getElementById("_hp")?.value) return;
  if (Date.now() - _t0 < 1500) return;
  const name   = document.getElementById("buyerName").value.trim();
  const email  = document.getElementById("buyerEmail").value.trim().toLowerCase();
  const referral = document.getElementById("referralCode").value.trim().toUpperCase();
  const coupon   = document.getElementById("couponCode").value.trim().toUpperCase();
  const client_ref = uuidv4();
  const mobile   = iti.getNumber();
  const country  = (iti.getSelectedCountryData().iso2 || "in").toLowerCase();
  const isIndia  = country === "in";
  const price    = isIndia ? Number(_settings?.product_price_india||_settings?.product_price||999) : Number(_settings?.product_price_global||19);
  const currency = isIndia ? "INR" : "USD";
  if (!name)                                 { alert("❌ Please enter your name."); return; }
  if (!email || !/\S+@\S+\.\S+/.test(email)) { alert("❌ Please enter a valid email."); return; }
  if (!iti.isValidNumber()) {
    mobileInput.style.borderColor = "var(--red)";
    setTimeout(() => mobileInput.style.borderColor = "", 2000);
    alert("❌ Please enter a valid mobile number."); return;
  }
  mobileInput.style.borderColor = "";
  document.getElementById("btnBuy").disabled = true;
  document.getElementById("processingMsg").textContent = "Creating payment order…";
  showState("stateProcessing");
  let order;
  try {
    const res = await fetch(ORDER_URL, {
      method: "POST",
      headers: { "Content-Type":"application/json", "Authorization":"Bearer "+SB_ANON_KEY, "apikey":SB_ANON_KEY },
      body: JSON.stringify({ name, email, mobile, country, price, currency, referral, coupon, client_ref })
    });
    if (!res.ok) { const e = await res.json().catch(()=>({})); throw new Error(e.error||"Server error "+res.status); }
    order = await res.json();
    if (!order.order_id) throw new Error("No order ID returned.");
  } catch(e) {
    document.getElementById("errorMsg").textContent = "Could not create order. Check your internet and try again. (" + e.message + ")";
    document.getElementById("btnBuy").disabled = false;
    showState("stateError"); return;
  }
  showState("stateForm");
  const rzp = new Razorpay({
    key: RAZORPAY_KEY_ID, amount: order.amount, currency: order.currency,
    order_id: order.order_id, name: "naadOdesk", description: "Perpetual License",
    prefill: { name, email, contact: mobile },
    notes:   { name, email, mobile, country, referral, coupon },
    theme:   { color: "#0a84ff" },
    modal:   { ondismiss: () => { document.getElementById("btnBuy").disabled = false; } },
    handler: async function(response) {
      document.getElementById("processingMsg").textContent = "Finalizing payment…";
      showState("stateProcessing");
      const paymentId = response.razorpay_payment_id;
      const CHECK_URL = SB_URL + "/functions/v1/check-license";
      for (let i = 0; i < 12; i++) {
        try {
          const r = await fetch(CHECK_URL, {
            method:"POST",
            headers:{"Content-Type":"application/json","apikey":SB_ANON_KEY,"Authorization":"Bearer "+SB_ANON_KEY},
            body: JSON.stringify({payment_id: paymentId})
          });
          if (r.ok) { const j = await r.json(); if (j?.license_key) { break; } }
        } catch(e) {}
        await new Promise(r => setTimeout(r, 5000));
      }
      // Show success
      document.getElementById("processingMsg").textContent = "✅ Payment successful! Check your email for the license key.";
      showState("stateSuccess");
    }
  });
  rzp.open();
}

// ── Scroll reveal ─────────────────────────────────────────────
const _observer = new IntersectionObserver((entries) => {
  entries.forEach(e => { if (e.isIntersecting) { e.target.classList.add("v"); _observer.unobserve(e.target); } });
}, { threshold: 0.1 });
document.querySelectorAll(".reveal").forEach(el => _observer.observe(el));

// ── FAQ accordion ─────────────────────────────────────────────
document.querySelectorAll(".faq-q").forEach(q => {
  q.addEventListener("click", () => {
    const item = q.parentElement;
    item.classList.toggle("open");
  });
});
</script>
</body>
</html>