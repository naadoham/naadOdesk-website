<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>naadOdesk — Music Production Management</title>
<meta name="description" content="Track every music project from first idea to final release. Native macOS app for music producers.">
<link rel="icon" href="data:image/png;base64," type="image/png">
<link href="https://fonts.googleapis.com/css2?family=Syne:wght@700;800&family=DM+Mono:wght@400;500&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/intl-tel-input@18.2.1/build/css/intlTelInput.css"/>
<style>
*{box-sizing:border-box;margin:0;padding:0}
:root{
  --bg:#080810;--card:#13131f;--border:#1e1e30;--border2:#252538;
  --accent:#0a84ff;--green:#30d158;--amber:#ffd60a;--red:#ff4e6a;
  --text:#eff0f8;--muted:#6b6b8f;--faint:#2a2a42;
  --h:'Syne',sans-serif;--b:'DM Sans',sans-serif;--m:'DM Mono',monospace;
}
body{background:var(--bg);color:var(--text);font-family:var(--b);overflow-x:hidden;font-size:14px;line-height:1.6}


/* ── DOWNLOAD SECTION ── */
.dl-hero{text-align:center;padding:48px 24px;background:linear-gradient(180deg,rgba(10,132,255,.04) 0%,transparent 100%);border-bottom:1px solid var(--border)}
.dl-hero h2{font-family:var(--h);font-size:clamp(28px,4vw,44px);font-weight:800;letter-spacing:-1.5px;color:#fff;margin-bottom:12px;line-height:1.08}
.dl-hero p{font-size:15px;color:var(--muted);max-width:440px;margin:0 auto 22px;line-height:1.7}
.dl-btn{display:inline-flex;align-items:center;gap:10px;padding:16px 36px;background:var(--accent);color:#fff;border-radius:10px;font-size:15px;font-weight:700;cursor:pointer;border:none;font-family:var(--b);transition:all .2s;box-shadow:0 0 40px rgba(10,132,255,.25);text-decoration:none}
.dl-btn:hover{opacity:.9;transform:translateY(-2px);box-shadow:0 10px 50px rgba(10,132,255,.35)}
.dl-btn:disabled{opacity:.5;cursor:not-allowed;transform:none}
.dl-btn svg{flex-shrink:0}
.dl-meta{display:flex;align-items:center;justify-content:center;gap:20px;margin-top:18px;flex-wrap:wrap}
.dl-meta-item{display:flex;align-items:center;gap:6px;font-size:12px;color:var(--muted);font-family:var(--m)}
.dl-meta-item strong{color:#aaa}
.dl-notes{max-width:540px;margin:28px auto 0;background:var(--card);border:1px solid var(--border);border-radius:10px;padding:18px 22px;text-align:left}
.dl-notes-label{font-family:var(--m);font-size:9px;letter-spacing:2px;text-transform:uppercase;color:var(--accent);margin-bottom:10px}
.dl-notes-text{font-size:12.5px;color:var(--muted);line-height:1.7}
.win-waitlist{display:flex;align-items:center;justify-content:center;gap:10px;margin-top:22px;padding:14px 24px;background:rgba(255,214,10,.05);border:1px solid rgba(255,214,10,.15);border-radius:10px;max-width:400px;margin-left:auto;margin-right:auto}
.win-waitlist-text{font-size:13px;color:var(--muted);line-height:1.5}
.win-waitlist-text strong{color:var(--amber)}
.win-icon{font-size:22px;flex-shrink:0}

/* ── NAV ── */
.nav{position:sticky;top:0;z-index:100;padding:14px 32px;display:flex;align-items:center;justify-content:space-between;background:rgba(8,8,16,0.93);backdrop-filter:blur(20px);border-bottom:1px solid rgba(30,30,48,.8)}
.nav-logo{display:flex;align-items:center;gap:9px;text-decoration:none}
.nav-logo img{width:28px;height:28px;border-radius:7px}
.nav-logo-text{font-family:var(--h);font-size:16px;font-weight:700;color:#fff}
.nav-cta{padding:8px 18px;background:var(--accent);color:#fff;border-radius:7px;font-size:12px;font-weight:600;cursor:pointer;border:none;font-family:var(--b);transition:opacity .2s,transform .2s;text-decoration:none;display:inline-block}
.nav-cta:hover{opacity:.88;transform:translateY(-1px)}

/* ── HERO ── */
.hero{min-height:75vh;display:flex;flex-direction:column;align-items:center;justify-content:center;text-align:center;padding:50px 24px 40px;position:relative;overflow:hidden}
.hero-glow{position:absolute;top:15%;left:50%;transform:translateX(-50%);width:700px;height:420px;pointer-events:none;background:radial-gradient(ellipse,rgba(10,132,255,.10) 0%,rgba(94,92,230,.05) 45%,transparent 72%)}
.hero-badge{display:inline-flex;align-items:center;gap:7px;padding:5px 13px;background:rgba(10,132,255,.08);border:1px solid rgba(10,132,255,.2);border-radius:100px;font-size:11px;color:var(--accent);font-family:var(--m);letter-spacing:.5px;margin-bottom:26px;animation:fadeUp .5s ease both}
.badge-dot{width:6px;height:6px;background:var(--accent);border-radius:50%;animation:pulse 2s infinite}
.win-soon{display:inline-flex;align-items:center;gap:5px;padding:3px 10px;background:rgba(255,214,10,.08);border:1px solid rgba(255,214,10,.2);border-radius:100px;font-size:10px;color:var(--amber);font-family:var(--m);margin-left:8px;vertical-align:middle}
@keyframes pulse{0%,100%{opacity:1}50%{opacity:.25}}
.hero h1{font-family:var(--h);font-size:clamp(36px,6vw,68px);font-weight:800;line-height:1.06;letter-spacing:-2px;color:#fff;max-width:700px;margin:0 auto 12px;animation:fadeUp .5s .1s ease both}
.grad{background:linear-gradient(135deg,#0a84ff,#5e5ce6);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text}
.hero-sub{font-size:clamp(14px,2vw,17px);color:var(--muted);max-width:480px;margin:0 auto 24px;line-height:1.75;animation:fadeUp .5s .2s ease both}
.hero-actions{display:flex;align-items:center;gap:12px;flex-wrap:wrap;justify-content:center;animation:fadeUp .5s .3s ease both}
.btn-primary{display:inline-flex;align-items:center;gap:8px;padding:13px 28px;background:var(--accent);color:#fff;border-radius:9px;font-size:14px;font-weight:600;cursor:pointer;border:none;font-family:var(--b);transition:all .2s;box-shadow:0 0 40px rgba(10,132,255,.2);text-decoration:none}
.btn-primary:hover{opacity:.9;transform:translateY(-2px);box-shadow:0 8px 40px rgba(10,132,255,.3)}
.btn-secondary{display:inline-flex;align-items:center;gap:7px;padding:13px 22px;background:transparent;border:1px solid var(--border2);color:var(--text);border-radius:9px;font-size:14px;cursor:pointer;font-family:var(--b);transition:all .2s;text-decoration:none}
.btn-secondary:hover{border-color:var(--accent);color:var(--accent);transform:translateY(-2px)}
.price-note{margin-top:12px;font-size:12px;color:var(--muted);font-family:var(--m);animation:fadeUp .5s .4s ease both}
.price-note strong{color:var(--green)}

/* ── APP MOCKUP ── */
.app-wrap{max-width:860px;margin:0 auto;padding:0 24px 40px;animation:fadeUp .6s .5s ease both}
.frame{background:var(--card);border:1px solid var(--border2);border-radius:14px;overflow:hidden;box-shadow:0 0 0 1px rgba(255,255,255,.03),0 40px 80px rgba(0,0,0,.5),0 0 60px rgba(10,132,255,.05)}
.wbar{display:flex;align-items:center;gap:6px;padding:11px 14px;background:#0b0b15;border-bottom:1px solid var(--border)}
.wd{width:11px;height:11px;border-radius:50%}
.wtitle{flex:1;text-align:center;font-size:11px;color:var(--muted);font-family:var(--m);margin-left:-44px}
.app{display:grid;grid-template-columns:180px 1fr;height:300px}
.sb{background:#090913;border-right:1px solid var(--border);padding:10px 0;overflow:hidden}
.sb-sec{padding:5px 12px;font-family:var(--m);font-size:9px;text-transform:uppercase;letter-spacing:1px;color:#2a2a45;margin-top:8px}
.sb-item{display:flex;align-items:center;gap:8px;padding:7px 14px;font-size:11px;color:var(--muted);font-family:var(--m);letter-spacing:.3px}
.sb-item.a{background:rgba(10,132,255,.1);color:var(--accent);border-right:2px solid var(--accent)}
.main{padding:14px;overflow:hidden}
.wpills{display:flex;gap:5px;margin-bottom:9px;flex-wrap:wrap}
.wp{border-radius:4px;padding:2px 7px;font-size:9px;font-family:var(--m);border:1px solid}
.row{display:flex;align-items:center;gap:9px;padding:8px 9px;border-radius:7px;margin-bottom:4px;background:rgba(255,255,255,.02);border:1px solid transparent;animation:rowIn .4s ease both}
.row:nth-child(1){animation-delay:.7s}.row:nth-child(2){animation-delay:.85s}
@keyframes rowIn{from{opacity:0;transform:translateX(8px)}to{opacity:1;transform:translateX(0)}}
.rbar{width:3px;height:26px;border-radius:2px;flex-shrink:0}
.ri{flex:1;min-width:0}
.rn{font-size:12px;font-weight:600;color:#dde;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;font-family:var(--m)}
.rm{font-size:9.5px;color:var(--muted);font-family:var(--m);margin-top:1px}
.tag{font-size:9px;font-weight:700;font-family:var(--m);padding:3px 7px;border-radius:4px;white-space:nowrap;flex-shrink:0;border:1px solid}

/* ── STRIP ── */
.strip{text-align:center;padding:22px 24px;border-top:1px solid var(--border);border-bottom:1px solid var(--border);background:rgba(255,255,255,.01)}
.strip-label{font-size:10px;color:var(--muted);font-family:var(--m);letter-spacing:1.5px;text-transform:uppercase;margin-bottom:18px}
.badges{display:flex;align-items:center;justify-content:center;gap:28px;flex-wrap:wrap}
.bi{display:flex;flex-direction:column;align-items:center;gap:2px}
.bi-num{font-family:var(--h);font-size:22px;font-weight:800;color:#fff}
.bi-label{font-size:11px;color:var(--muted)}
.sep{width:1px;height:32px;background:var(--border)}

/* ── SECTIONS ── */
.section{max-width:1000px;margin:0 auto;padding:50px 24px}
.s-label{font-family:var(--m);font-size:10px;letter-spacing:2px;text-transform:uppercase;color:var(--accent);margin-bottom:12px}
.s-title{font-family:var(--h);font-size:clamp(26px,4vw,42px);font-weight:800;letter-spacing:-1.5px;color:#fff;margin-bottom:14px;line-height:1.08}
.s-sub{font-size:15px;color:var(--muted);max-width:460px;line-height:1.75;margin-bottom:30px}
.feat-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));gap:14px}
.feat{background:var(--card);border:1px solid var(--border);border-radius:12px;padding:22px;transition:all .3s;position:relative;overflow:hidden}
.feat::before{content:'';position:absolute;top:0;left:10%;right:10%;height:1px;background:linear-gradient(90deg,transparent,var(--fc,var(--accent)),transparent);opacity:0;transition:opacity .3s}
.feat:hover{border-color:var(--border2);transform:translateY(-3px);box-shadow:0 16px 40px rgba(0,0,0,.25)}
.feat:hover::before{opacity:1}
.fi{font-size:22px;margin-bottom:12px;display:block}
.ft{font-family:var(--h);font-size:14.5px;font-weight:700;color:#fff;margin-bottom:7px}
.fd{font-size:12.5px;color:var(--muted);line-height:1.65}
.how-bg{background:linear-gradient(180deg,transparent,rgba(10,132,255,.025),transparent);border-top:1px solid var(--border);border-bottom:1px solid var(--border)} .how-bg .section{padding:40px 24px}
.steps{display:grid;grid-template-columns:repeat(4,1fr);margin-top:50px;border:1px solid var(--border);border-radius:12px;overflow:hidden}
.step{padding:26px 22px;border-right:1px solid var(--border)}
.step:last-child{border-right:none}
.sn{font-family:var(--m);font-size:10px;color:var(--accent);letter-spacing:1px;margin-bottom:12px;display:block}
.stitle{font-family:var(--h);font-size:13.5px;font-weight:700;color:#fff;margin-bottom:7px}
.sdesc{font-size:12px;color:var(--muted);line-height:1.6}

/* ── PRICING + BUY FORM ── */
.pricing-wrap{text-align:center;margin-bottom:30px}
.buy-grid{display:grid;grid-template-columns:1fr 1fr;gap:24px;max-width:900px;margin:0 auto;align-items:start}
.p-card{background:var(--card);border:1px solid var(--border2);border-radius:18px;padding:36px;position:relative;overflow:hidden}
.p-card::before{content:'';position:absolute;top:0;left:15%;right:15%;height:1px;background:linear-gradient(90deg,transparent,var(--accent),transparent)}
.p-badge{display:inline-block;font-family:var(--m);font-size:9px;letter-spacing:2px;text-transform:uppercase;color:var(--green);background:rgba(48,209,88,.08);border:1px solid rgba(48,209,88,.2);padding:4px 11px;border-radius:100px;margin-bottom:20px}
.p-amt{display:flex;align-items:flex-start;gap:5px;margin-bottom:5px}
.p-sym{font-size:22px;color:#fff;font-weight:700;margin-top:8px;font-family:var(--h)}
.p-num{font-family:var(--h);font-size:66px;font-weight:800;color:#fff;line-height:1;letter-spacing:-3px;min-width:80px}
.p-num.loading{opacity:.3;animation:blink 1s infinite}
@keyframes blink{0%,100%{opacity:.3}50%{opacity:.6}}
.p-desc{font-size:12px;color:var(--muted);margin-bottom:24px}
.p-list{list-style:none;display:flex;flex-direction:column;gap:10px;text-align:left}
.p-list li{display:flex;align-items:center;gap:9px;font-size:13px;color:#ccc}
.chk{width:17px;height:17px;background:rgba(48,209,88,.1);border:1px solid rgba(48,209,88,.22);border-radius:50%;display:flex;align-items:center;justify-content:center;flex-shrink:0;font-size:9px;color:var(--green)}

/* Buy form card */
.buy-card{background:var(--card);border:1px solid var(--border2);border-radius:18px;padding:28px;position:relative;overflow:hidden}
.buy-card::before{content:'';position:absolute;top:0;left:15%;right:15%;height:1px;background:linear-gradient(90deg,transparent,var(--accent),transparent)}
.state{display:none}.state.active{display:block}
.form-group{margin-bottom:13px}
label{display:block;font-size:10px;font-weight:600;color:var(--muted);text-transform:uppercase;letter-spacing:.6px;margin-bottom:5px;font-family:var(--m)}
.req{color:var(--red);margin-left:2px}
input[type=text],input[type=email],input[type=tel]{width:100%;background:#0d0d18;border:1px solid var(--border2);border-radius:8px;padding:10px 13px;color:var(--text);font-size:13px;font-family:var(--b);outline:none;transition:border-color .2s}
input:focus{border-color:var(--accent)}
input::placeholder{color:var(--faint)}
input:disabled{opacity:.5}
.apply-btn{width:100%;padding:9px;background:rgba(10,132,255,.08);border:1px solid rgba(10,132,255,.25);border-radius:7px;color:var(--accent);font-size:12px;font-weight:600;cursor:pointer;font-family:var(--b);margin-bottom:9px;transition:background .2s}
.apply-btn:hover{background:rgba(10,132,255,.15)}
.discount-box{display:none;background:rgba(48,209,88,.04);border:1px solid rgba(48,209,88,.18);border-radius:8px;padding:11px 13px;margin-bottom:9px}
.btn-buy-form{width:100%;padding:14px;background:var(--accent);color:#fff;border-radius:9px;font-size:14px;font-weight:600;cursor:pointer;border:none;font-family:var(--b);transition:all .2s;box-shadow:0 0 24px rgba(10,132,255,.2);margin-top:4px}
.btn-buy-form:hover{opacity:.9;transform:translateY(-1px)}
.btn-buy-form:disabled{opacity:.5;cursor:not-allowed;transform:none}
.pay-row{display:flex;align-items:center;justify-content:center;gap:6px;margin-top:12px;flex-wrap:wrap}
.pay-row span{font-size:10px;color:var(--muted)}
.pay-badge{background:rgba(255,255,255,.04);border:1px solid var(--border);border-radius:4px;padding:3px 7px;font-size:10px;color:#888}
.state-center{text-align:center;padding:32px 16px}
.spinner{width:38px;height:38px;border:3px solid var(--border2);border-top-color:var(--accent);border-radius:50%;animation:spin 1s linear infinite;margin:0 auto 16px}
@keyframes spin{to{transform:rotate(360deg)}}
.state-center .msg{font-size:12px;color:var(--muted);margin-top:5px}
.success-icon{font-size:48px;margin-bottom:12px}
.success-title{font-size:18px;font-weight:800;color:var(--green);margin-bottom:8px;font-family:var(--h)}
.success-sub{font-size:12.5px;color:var(--muted);line-height:1.7}
.act-box{background:#0a0a14;border:1px solid var(--border2);border-radius:9px;padding:14px;margin:14px 0;text-align:left}
.act-box h4{font-size:9px;font-weight:600;color:var(--muted);text-transform:uppercase;letter-spacing:.8px;margin-bottom:9px;font-family:var(--m)}
.act-step{display:flex;gap:9px;align-items:flex-start;margin-bottom:7px;font-size:12px;color:var(--muted)}
.act-num{width:18px;height:18px;border-radius:50%;background:rgba(10,132,255,.12);border:1px solid rgba(10,132,255,.25);color:var(--accent);font-size:9px;font-weight:700;display:flex;align-items:center;justify-content:center;flex-shrink:0}
.error-icon{font-size:42px;margin-bottom:10px}
.error-title{font-size:16px;font-weight:700;color:var(--red);margin-bottom:7px;font-family:var(--h)}
.error-msg{font-size:12px;color:var(--muted);margin-bottom:14px;line-height:1.6}
.btn-retry{padding:9px 20px;background:transparent;border:1px solid var(--border2);color:var(--text);border-radius:7px;font-size:12px;cursor:pointer;font-family:var(--b)}
.btn-retry:hover{border-color:var(--accent);color:var(--accent)}
.hp{display:none!important}
.privacy{font-size:10px;color:var(--muted);text-align:center;margin-top:9px;line-height:1.6}
.privacy a{color:var(--accent);text-decoration:none}

/* intl-tel-input overrides */
.iti{width:100%;position:relative;display:block}
.iti__country-list{position:absolute!important;top:calc(100% + 4px)!important;left:0!important;width:100%!important;max-height:220px!important;overflow-y:auto!important;z-index:9999!important;background:#1a1a24!important;border:1px solid #2a2a3e!important;border-radius:10px!important;box-shadow:0 8px 28px rgba(0,0,0,.6)!important;scrollbar-width:thin;scrollbar-color:#2a2a3e transparent}
.iti__country{display:flex!important;align-items:center!important;gap:8px!important;padding:8px 13px!important;font-size:12px!important;color:#f0f0f8!important;cursor:pointer!important}
.iti__country.iti__highlight,.iti__country:hover{background:rgba(10,132,255,.1)!important}
.iti__dial-code{color:#6a6a8a!important;font-size:11px!important}
.iti__divider{border:none!important;border-top:1px solid #2a2a3e!important;margin:3px 0!important}
.iti--separate-dial-code .iti__selected-flag{background:rgba(255,255,255,.04)!important;border-right:1px solid #2a2a3e!important;border-radius:8px 0 0 8px!important;padding:0 10px 0 11px!important}
.iti--separate-dial-code input[type=tel]{border-radius:0 8px 8px 0!important;padding-left:88px!important}
.iti__flag{background-image:url("https://cdn.jsdelivr.net/npm/intl-tel-input@18.2.1/build/img/flags.png")}
@media(-webkit-min-device-pixel-ratio:2),(min-resolution:192dpi){.iti__flag{background-image:url("https://cdn.jsdelivr.net/npm/intl-tel-input@18.2.1/build/img/flags@2x.png")}}

/* FAQ */
.faq-item{border-bottom:1px solid var(--border);padding:20px 0}
.faq-q{font-family:var(--h);font-size:14px;font-weight:700;color:#fff;margin-bottom:9px}
.faq-a{font-size:13px;color:var(--muted);line-height:1.7}
.faq-a a{color:var(--accent);text-decoration:none}
footer{border-top:1px solid var(--border);padding:24px 24px;text-align:center}
.footer-logo{display:flex;align-items:center;gap:8px;justify-content:center;margin-bottom:10px}
.footer-logo img{width:26px;height:26px;border-radius:6px}
.fl-text{font-family:var(--h);font-size:15px;font-weight:700;color:#fff}
footer p{font-size:11.5px;color:var(--muted);line-height:1.9}
footer a{color:var(--accent);text-decoration:none}
@keyframes fadeUp{from{opacity:0;transform:translateY(18px)}to{opacity:1;transform:translateY(0)}}

/* ── PROMO BANNER ── */
#promoBanner{display:none;width:100%;position:sticky;top:0;z-index:9999;background:linear-gradient(90deg,#1a1400 0%,#1f1700 40%,#1a1400 100%);border-bottom:2px solid rgba(255,214,10,.45);box-shadow:0 4px 32px rgba(255,214,10,.18);animation:fadeDown .5s ease both}
@keyframes fadeDown{from{opacity:0;transform:translateY(-100%)}to{opacity:1;transform:translateY(0)}}
.promo-inner{max-width:900px;margin:0 auto;padding:14px 28px;display:flex;align-items:center;gap:20px;position:relative}
.promo-inner::before{content:'';position:absolute;bottom:0;left:10%;right:10%;height:1px;background:linear-gradient(90deg,transparent,rgba(255,214,10,.4),transparent)}
.promo-lightning{font-size:32px;flex-shrink:0;filter:drop-shadow(0 0 10px rgba(255,214,10,.8));animation:zpulse 2s ease-in-out infinite}
@keyframes zpulse{0%,100%{transform:scale(1)}50%{transform:scale(1.12)}}
.promo-content{flex:1;min-width:0}
.promo-pill{display:inline-block;font-family:'Inter',var(--m),sans-serif;font-size:10px;letter-spacing:2.5px;text-transform:uppercase;color:var(--amber);background:rgba(255,214,10,.12);border:1px solid rgba(255,214,10,.35);padding:4px 12px;border-radius:100px;margin-bottom:7px;font-weight:700}
.promo-tagline{font-family:'Inter',var(--h),sans-serif;font-size:clamp(15px,2.2vw,19px);font-weight:700;color:#fff;margin-bottom:6px;line-height:1.3;letter-spacing:-.2px}
.promo-code-row{display:flex;align-items:center;gap:10px;flex-wrap:wrap}
.promo-code-label{font-size:13px;color:rgba(255,255,255,.6);font-family:'Inter',var(--b),sans-serif}
.promo-code-chip{font-family:'Inter','Courier New',var(--m),monospace;font-size:15px;font-weight:800;color:#1a1400;background:var(--amber);border:none;border-radius:8px;padding:6px 16px;letter-spacing:2.5px;cursor:pointer;transition:all .18s;user-select:all;box-shadow:0 2px 16px rgba(255,214,10,.35)}
.promo-code-chip:hover{background:#ffe040;transform:scale(1.05);box-shadow:0 4px 24px rgba(255,214,10,.55)}
.promo-copied{font-size:12px;color:#4ade80;font-family:'Inter',var(--m),sans-serif;font-weight:600;display:none}
.promo-disc{font-family:'Inter',var(--h),sans-serif;font-size:clamp(30px,4.5vw,44px);font-weight:900;color:var(--amber);flex-shrink:0;letter-spacing:-2px;text-shadow:0 0 24px rgba(255,214,10,.45);line-height:1}
.promo-disc small{font-size:14px;font-weight:500;color:rgba(255,255,255,.55);display:block;text-align:right;margin-top:2px;font-family:'Inter',var(--b),sans-serif;letter-spacing:0}
.reveal{opacity:1;transform:none;transition:opacity .45s ease,transform .45s ease}
.reveal.v{opacity:1;transform:none}
.d1{transition-delay:.1s}.d2{transition-delay:.2s}
@media(max-width:780px){
  .nav{padding:12px 16px}
  .app{grid-template-columns:1fr}.sb{display:none}
  .steps{grid-template-columns:1fr 1fr}
  .step{border-right:none;border-bottom:1px solid var(--border)}
  .step:last-child{border-bottom:none}
  .buy-grid{grid-template-columns:1fr}
}
</style>
